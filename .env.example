# -------------------------------------------------
# Reverse proxy / DNS (Traefik)
# -------------------------------------------------
DOMAIN=api.example.com

# -------------------------------------------------
# Application
# -------------------------------------------------
NODE_ENV=production
PORT=5000
JWT_SECRET=change_me_with_a_long_random_secret
JWT_EXPIRES_IN=30m
AUTO_START_MONITORING=false

# -------------------------------------------------
# MongoDB (service docker "mongodb")
# -------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=change_me_root_user
MONGO_INITDB_ROOT_PASSWORD=change_me_root_password
MONGO_INITDB_DATABASE=village_connecte
MONGO_URI=mongodb://change_me_root_user:change_me_root_password@mongodb:27017/village_connecte?authSource=admin

# -------------------------------------------------
# API / Monitoring credentials
# -------------------------------------------------
API_BASE=https://api.example.com
API_TOKEN=
API_LOGIN=change_me_api_login
API_PASSWORD=change_me_api_password

# -------------------------------------------------
# Monitoring réseau
# -------------------------------------------------
SNMP_COMMUNITY=public
IF_INDEX=1
MONITORING_INTERVAL=5000
PING_TIMEOUT=2
GATEWAY_IP_FALLBACK=

# -------------------------------------------------
# MikroTik
# -------------------------------------------------
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=change_me_mikrotik_password
MIKROTIK_SSL=false
MIKROTIK_TIMEOUT=10000

# -------------------------------------------------
# Agent script optionnel
# -------------------------------------------------
BORNE_IP=192.168.70.2
BORNE_NAME=UVCI-STAGE
